---
import { SITE } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 · 页面不存在" noIndex={true}>
  <div class="not-found">
    <div class="nf-content">
      <div class="nf-code">404</div>
      <h1 class="nf-title">页面不存在</h1>
      <p class="nf-desc">你要找的页面可能已被删除、移动，或从未存在过。</p>
      <div class="nf-actions">
        <a class="btn-primary" href="/">返回首页</a>
        <a class="btn-secondary" href="/archives">查看归档</a>
      </div>
    </div>
    <div class="nf-deco" aria-hidden="true">¶</div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - var(--nav-height) - 100px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    position: relative;
    overflow: hidden;
  }
  .nf-content { text-align: center; position: relative; z-index: 1; }
  .nf-code {
    font-family: var(--font-serif);
    font-size: 120px;
    font-weight: 700;
    color: var(--accent-soft);
    line-height: 1;
    margin-bottom: -16px;
    background: linear-gradient(135deg, var(--accent), #a29bfe);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    user-select: none;
  }
  .nf-title {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .nf-desc {
    font-size: 15px;
    color: var(--text-meta);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .nf-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    padding: 10px 24px;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    transition: opacity .2s, transform .2s;
  }
  .btn-primary:hover { opacity: .88; transform: translateY(-1px); }
  .btn-secondary {
    padding: 10px 24px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-meta);
    font-size: 14px;
    font-weight: 600;
    transition: all .2s;
  }
  .btn-secondary:hover { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }
  .nf-deco {
    position: absolute;
    font-size: 360px;
    font-family: var(--font-serif);
    color: var(--border);
    opacity: .3;
    user-select: none;
    pointer-events: none;
    line-height: 1;
    right: -60px;
    bottom: -80px;
  }
</style>
