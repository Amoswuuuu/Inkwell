---
import { getCollection, render } from 'astro:content';
import { SITE } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';
import GiscusComments from '../components/GiscusComments.astro';

// 获取关于页面内容
const pages = await getCollection('pages');
const aboutPage = pages.find(p => p.id === 'about.md' || p.id === 'about');
if (!aboutPage) {
  return Astro.redirect('/404');
}

const { Content } = await render(aboutPage);
---

<BaseLayout title={aboutPage.data.title} description={aboutPage.data.description}>
  <div class="page-wrap">
    <div class="about-hero">
      <img class="about-avatar" src={SITE.author.avatar} alt={SITE.author.name} loading="lazy" decoding="async" fetchpriority="low" />
      <div class="about-info">
        <h1 class="about-name">{SITE.author.name}</h1>
        <p class="about-bio">{SITE.author.bio}</p>
        <div class="about-social">
          {SITE.social.github && (
            <a class="social-link" href={`https://github.com/${SITE.social.github}`} target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {SITE.social.email && (
            <a class="social-link" href={`mailto:${SITE.social.email}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="about-content prose">
      <Content />
    </div>

    <GiscusComments />
  </div>
</BaseLayout>

<style>
  .page-wrap { max-width: 780px; margin: 0 auto; padding: 48px 24px 80px; }

  .about-hero {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 48px;
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .about-avatar {
    width: 96px; height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--accent-soft);
    flex-shrink: 0;
  }
  .about-name {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .about-bio {
    font-size: 14px;
    color: var(--text-meta);
    line-height: 1.6;
    white-space: pre-line;
    margin-bottom: 14px;
  }
  .about-social { display: flex; gap: 10px; flex-wrap: wrap; }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 13px;
    color: var(--text-meta);
    transition: all .2s;
  }
  .social-link:hover { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }

  .about-content {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 36px 40px;
  }

  @media (max-width: 640px) {
    .page-wrap { padding: 32px 16px 60px; }
    .about-hero { flex-direction: column; text-align: center; padding: 24px; gap: 20px; }
    .about-social { justify-content: center; }
    .about-content { padding: 24px 18px; }
  }
</style>