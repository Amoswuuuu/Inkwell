---
import { getCollection } from 'astro:content';
import { SITE } from '../config';
import { buildSidebarData, formatChars } from '../utils/posts';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import PostCard from '../components/PostCard.astro';
import PostCardVertical from '../components/PostCardVertical.astro';
import ProfileWidget from '../components/widgets/ProfileWidget.astro';
import CategoryWidget from '../components/widgets/CategoryWidget.astro';
import TagCloudWidget from '../components/widgets/TagCloudWidget.astro';
import SiteInfoWidget from '../components/widgets/SiteInfoWidget.astro';

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.published !== false)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 精选文章（置顶展示）
const featuredPosts = allPosts.filter(p => p.data.featured === true).slice(0, 3);

// 侧边栏数据（共享逻辑，提取到 utils/posts.ts）
const { categories, tags, totalChars, lastPostDate } = buildSidebarData(allPosts);

const listStyle = SITE.post.listStyle ?? 'horizontal';
const POSTS_PER_PAGE = SITE.postsPerPage;
const pagedPosts = allPosts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <HeroBanner
    postCount={allPosts.length}
    categoryCount={categories.length}
    tagCount={tags.length}
  />

  <div class="main-wrap main-wrap-index">
    <main class="post-column">

      {/* ── Featured posts (only rendered if any post has featured: true) ── */}
      {featuredPosts.length > 0 && (
        <section class="featured-section">
          <div class="section-header">
            <div class="section-header-line"></div>
            <span class="section-header-text">精选推荐</span>
            <span class="section-header-sub">编辑精选，从这里开始</span>
          </div>
          <div class="featured-grid">
            {featuredPosts.map(post => (
              <a class="featured-card" href={`/posts/${post.data.abbrlink || post.id}/`}>
                {post.data.cover && (
                  <div class="featured-card-img" style={`background-image: url('${post.data.cover}')`}></div>
                )}
                {!post.data.cover && <div class="featured-card-img featured-card-img-placeholder"></div>}
                <div class="featured-card-body">
                  <div class="featured-card-cats">
                    {(Array.isArray(post.data.categories) ? post.data.categories : post.data.categories ? [post.data.categories] : []).slice(0, 1).map(c => (
                      <span class="featured-cat">{c}</span>
                    ))}
                  </div>
                  <h2 class="featured-card-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="featured-card-desc">{post.data.description}</p>
                  )}
                  <span class="featured-card-read">阅读全文 →</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="section-header">
        <div class="section-header-line"></div>
        <span class="section-header-text">最新文章</span>
      </div>

      <div class={listStyle === 'card' ? 'post-grid' : 'post-list'}>
        {pagedPosts.map(post => listStyle === 'card'
          ? (
            <PostCardVertical
              slug={post.data.abbrlink || post.id}
              title={post.data.title}
              date={post.data.date}
              cover={post.data.cover}
              categories={post.data.categories}
              tags={post.data.tags}
              description={post.data.description}
              aiSummary={post.data.ai_summary}
            />
          ) : (
            <PostCard
              slug={post.data.abbrlink || post.id}
              title={post.data.title}
              date={post.data.date}
              cover={post.data.cover}
              categories={post.data.categories}
              tags={post.data.tags}
              description={post.data.description}
              aiSummary={post.data.ai_summary}
            />
          )
        )}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="分页">
          <span class="page-btn disabled">‹</span>
          <span class="page-btn active">1</span>
          {totalPages === 2 && <a class="page-btn" href="/page/2">2</a>}
          {totalPages > 2 && (
            <>
              <a class="page-btn" href="/page/2">2</a>
              {totalPages > 3 && <span class="page-btn ellipsis">…</span>}
              {totalPages > 3 && <a class="page-btn" href={`/page/${totalPages}`}>{totalPages}</a>}
            </>
          )}
          <a class="page-btn" href="/page/2">›</a>
        </nav>
      )}
    </main>

    <aside class="sidebar">
      <ProfileWidget postCount={allPosts.length} categoryCount={categories.length} tagCount={tags.length} />
      <CategoryWidget categories={categories} />
      <TagCloudWidget tags={tags} />
      <SiteInfoWidget postCount={allPosts.length} tagCount={tags.length} wordCount={formatChars(totalChars)} lastPostDate={lastPostDate} />
    </aside>
  </div>
</BaseLayout>

<style>
  .main-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px var(--space-page) 64px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: var(--gap-section);
    align-items: start;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .section-header-line {
    width: 4px; height: 20px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .section-header-text {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .post-column {
    min-width: 0;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    min-width: 0;
  }
  .post-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    min-width: 0;
  }
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .page-btn {
    width: 36px; height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-meta);
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
  }
  .page-btn:hover, .page-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .page-btn.disabled { opacity: .4; pointer-events: none; }

  /* ── Featured Section ── */
  .featured-section { margin-bottom: 36px; }
  .section-header-sub {
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .featured-card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
    text-decoration: none;
    color: inherit;
  }
  .featured-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .featured-card-img {
    height: 160px;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }
  .featured-card-img-placeholder {
    background: linear-gradient(135deg, var(--accent-soft) 0%, var(--bg) 100%);
  }
  .featured-card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .featured-card-cats { display: flex; gap: 6px; }
  .featured-cat {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .featured-card-title {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text-primary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-card-desc {
    font-size: 13px;
    color: var(--text-meta);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .featured-card-read {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    margin-top: auto;
  }
  @media (max-width: 640px) {
    .featured-grid { grid-template-columns: 1fr; }
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: calc(var(--nav-height) + 20px);
    min-width: 0;
  }

  /* ── Tailwind lg breakpoint (1024px): stack sidebar ── */
  @media (max-width: 1024px) {
    .main-wrap {
      grid-template-columns: 1fr;
      padding: 24px 20px 48px;
    }
    .sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
  }

  /* ── Tailwind sm breakpoint (640px): tighter padding ── */
  @media (max-width: 640px) {
    .main-wrap { padding: 20px 16px 40px; }
    .sidebar { grid-template-columns: 1fr; }
  }

  /* Small phones (480px) */
  @media (max-width: 480px) {
    .main-wrap { padding: 16px 16px 36px; }
    .section-header-text { font-size: 16px; }
    .post-grid, .post-list { gap: 16px; }
  }
</style>
