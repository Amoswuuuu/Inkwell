---
import { SITE } from '../config';
import { displayTag } from '../utils/tag';
import { normalizeCats, normalizeTags } from '../utils/posts';

interface Props {
  slug: string;
  title: string;
  date: Date;
  cover?: string;
  categories?: string | string[];
  tags?: string | string[];
  description?: string;
  aiSummary?: string[];
}

const { slug, title, date, cover, categories, description, tags, aiSummary } = Astro.props;

// 首页卡片始终显示 description（完整一句话），不显示 AI 摘要要点列表
const excerpt = description || null;

const cats = normalizeCats(categories);
const rawTags = Array.isArray(tags) ? tags : (tags ? [tags] : []);
// Support comma-separated tag strings (e.g. "2021,原创,Qt")
const tagList = rawTags.flatMap(t => typeof t === 'string' && t.includes(',') ? t.split(',').map(s => s.trim()).filter(Boolean) : [t]);

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric', month: '2-digit', day: '2-digit',
}).replace(/\//g, '-');
---

<article class="post-card">
  <a href={`/posts/${slug}/`} class="post-card-img-wrap" aria-hidden="true" tabindex="-1">
    {cover && <img class="post-card-img" src={cover} alt={title} loading="lazy" decoding="async" fetchpriority="low" style="height:100%" />}
    {!cover && <div class="post-card-img-placeholder"></div>}
  </a>
  <div class="post-card-body">
    <div class="post-card-meta">
      {cats.slice(0, 1).map(cat => (
        <a class="badge" href={`/categories/${encodeURIComponent(cat)}`}>{cat}</a>
      ))}
      <span class="badge-date">{dateStr}</span>
    </div>
    <h2 class="post-card-title">
      <a href={`/posts/${slug}/`}>{title}</a>
    </h2>

    {/* Middle zone: description（完整一句话） */}
    <div class="post-card-middle">
      {excerpt
        ? <p class="post-card-excerpt">{excerpt}</p>
        : <div class="post-card-spacer"></div>
      }
    </div>

    <div class="post-card-footer">
      <div class="post-card-tags">
        {tagList.slice(0, 3).map(tag => (
          <a class="tag" href={`/tags/${encodeURIComponent(tag)}`}>#{displayTag(tag)}</a>
        ))}
      </div>
      <a class="read-more" href={`/posts/${slug}/`}>阅读全文</a>
    </div>
  </div>
</article>

<style>
  .post-card {
    background: var(--surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    transition: transform .25s, box-shadow .25s;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }
  .post-card-img-wrap {
    position: relative;
    overflow: hidden;
    min-height: 165px;
    min-width: 0;
    display: block;
  }
  .post-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .post-card-img-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--accent-soft), var(--tag-bg));
    min-height: 165px;
  }
  .post-card:hover .post-card-img { transform: scale(1.04); }

  .post-card-body {
    padding: 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 165px;
    min-width: 0;
    overflow: hidden;
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-flex;
    padding: 3px 10px;
    border-radius: var(--radius-badge);
    font-size: 12px;
    font-weight: 600;
    background: var(--tag-bg);
    color: var(--tag-text);
    white-space: nowrap;
    transition: background .2s, color .2s;
  }
  .badge:hover { background: var(--accent); color: #fff; }
  .badge-date { font-size: 12px; color: var(--text-muted); }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 700;
    line-height: 1.5;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .post-card-title a {
    color: var(--text-primary);
    transition: color .2s;
  }
  .post-card:hover .post-card-title a { color: var(--accent); }

  .post-card-middle {
    flex: 1;
    min-height: 48px;
    min-width: 0;
  }
  .post-card-excerpt {
    font-size: 14px;
    color: var(--text-meta);
    line-height: 1.75;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .post-card-ai {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .post-card-ai li {
    font-size: 12px;
    color: var(--text-meta);
    line-height: 1.5;
    padding-left: 12px;
    position: relative;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .post-card-ai li::before {
    content: '•';
    position: absolute;
    left: 3px;
    color: var(--accent);
    font-size: 10px;
  }
  .post-card-spacer { height: 100%; }
  .post-card-footer {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .post-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    min-width: 0;
    flex: 1;
    overflow: hidden;
  }
  .tag {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 4px;
    transition: color .2s, border-color .2s;
  }
  .tag:hover { color: var(--accent); border-color: var(--accent); }
  .read-more {
    margin-left: auto;
    font-size: 13px;
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }
  .read-more::after {
    content: "→";
    transition: transform .2s;
    display: inline-block;
  }
  .post-card:hover .read-more::after { transform: translateX(4px); }

  /* Large phones (720px): reduce fixed width */  
  @media (max-width: 720px) {
    .post-card { grid-template-columns: 160px minmax(0, 1fr); }
    .post-card-img-wrap { min-height: 140px; }
    .post-card-img-placeholder { min-height: 140px; }
  }

  /* ── Tailwind md breakpoint (768px) ── */
  @media (max-width: 680px) {
    .post-card { grid-template-columns: 140px minmax(0, 1fr); }
    .post-card-img-wrap { min-height: 130px; }
    .post-card-img-placeholder { min-height: 130px; }
    .post-card-body { padding: 12px 14px; gap: 8px; }
    .post-card-title { font-size: 16px; }
  }

  /* ── Tailwind sm breakpoint (640px): single column ── */
  @media (max-width: 640px) {
    .post-card { grid-template-columns: 1fr; }
    .post-card-img-wrap { min-height: 0; height: 180px; }
    .post-card-img-placeholder { min-height: 180px; }
    .post-card-body { padding: 16px; }
    .post-card-title { font-size: 18px; }
  }

  /* Small phones (480px) */
  @media (max-width: 480px) {
    .post-card-img-wrap, .post-card-img-placeholder { height: 160px; }
    .post-card-body { padding: 14px; gap: 8px; }
    .post-card-title { font-size: 17px; }
    .post-card-excerpt { -webkit-line-clamp: 2; }
  }

  /* Ultra-small phones (400px) */
  @media (max-width: 400px) {
    .post-card-img-wrap, .post-card-img-placeholder { height: 140px; }
    .post-card-body { padding: 12px; gap: 6px; }
    .post-card-title { font-size: 16px; }
    .badge { padding: 2px 8px; font-size: 11px; }
    .tag { padding: 2px 6px; font-size: 10px; }
  }
</style>
