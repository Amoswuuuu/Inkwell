---
interface Props {
  categories: { name: string; count: number }[];
}
const { categories } = Astro.props;

const colors = ['#4b7bec','#e17055','#00b894','#fdcb6e','#a29bfe','#fd79a8','#00cec9','#e84393'];
---

<div class="widget">
  <div class="widget-header">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    <span>文章分类</span>
  </div>
  <div class="widget-body">
    <div class="cat-list">
      {categories.map((cat, i) => (
        <a class="cat-item" href={`/categories/${encodeURIComponent(cat.name)}`}>
          <div class="cat-left">
            <div class="cat-dot" style={`background:${colors[i % colors.length]}`}></div>
            <span class="cat-name">{cat.name}</span>
          </div>
          <span class="cat-count">{cat.count}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .widget {
    background: var(--surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: background .3s, border-color .3s;
  }
  .widget-header {
    padding: 13px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
  }
  .widget-header span { color: var(--text-primary); }
  .widget-body { padding: 10px var(--space-widget); }
  .cat-list { display: flex; flex-direction: column; gap: 2px; }
  .cat-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 10px;
    border-radius: 8px;
    transition: background .2s;
    color: var(--text-primary);
  }
  .cat-item:hover { background: var(--accent-soft); }
  .cat-item:hover .cat-name { color: var(--accent); }
  .cat-left { display: flex; align-items: center; gap: 8px; }
  .cat-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .cat-name { font-size: 13px; transition: color .2s; }
  .cat-count {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--bg);
    padding: 1px 7px;
    border-radius: 10px;
  }
</style>
