---
import { SITE } from '../../config';

interface Props {
  name?: string;
  bio?: string;
  avatar?: string;
  postCount?: number;
  categoryCount?: number;
  tagCount?: number;
  social?: { github?: string; twitter?: string; email?: string };
}
const {
  name = SITE.author.name,
  bio = SITE.author.bio,
  avatar = SITE.author.avatar,
  postCount = 0,
  categoryCount = 0,
  tagCount = 0,
  social = SITE.social,
} = Astro.props;
---

<div class="widget profile-widget">
  <div class="widget-body">
    <div class="profile-top">
      <img class="profile-avatar" src={avatar} alt={name} loading="lazy" decoding="async" fetchpriority="low" />
      <div class="profile-name">{name}</div>
      <div class="profile-bio">{bio}</div>
    </div>
    <div class="profile-stats">
      <div class="profile-stat">
        <span class="profile-stat-num">{postCount}</span>
        <span class="profile-stat-label">文章</span>
      </div>
      <div class="profile-stat">
        <span class="profile-stat-num">{categoryCount}</span>
        <span class="profile-stat-label">分类</span>
      </div>
      <div class="profile-stat">
        <span class="profile-stat-num">{tagCount}</span>
        <span class="profile-stat-label">标签</span>
      </div>
    </div>
    {(social.github || social.twitter || social.email) && (
      <div class="social-links">
        {social.github && (
          <a class="social-btn" href={`https://github.com/${social.github}`} target="_blank" rel="noopener" title="GitHub">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        )}
        {social.twitter && (
          <a class="social-btn" href={`https://twitter.com/${social.twitter}`} target="_blank" rel="noopener" title="Twitter / X">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        )}
        {social.email && (
          <a class="social-btn" href={`mailto:${social.email}`} title="Email">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        )}
        <a class="social-btn" href="/rss.xml" title="RSS">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
        </a>
      </div>
    )}
  </div>
</div>

<style>
  .widget {
    background: var(--surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: background .3s, border-color .3s;
  }
  .widget-body { padding: 18px var(--space-card); }
  .profile-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 14px;
    text-align: center;
  }
  .profile-avatar {
    width: 72px; height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--accent-soft);
  }
  .profile-name {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .profile-bio {
    font-size: 12px;
    color: var(--text-meta);
    line-height: 1.6;
    white-space: pre-line;
  }
  .profile-stats {
    display: flex;
    justify-content: space-around;
    padding: 10px 0;
  }
  .profile-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .profile-stat-num {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
  }
  .profile-stat-label { font-size: 11px; color: var(--text-muted); }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    margin-top: 10px;
  }
  .social-btn {
    width: 30px; height: 30px;
    border-radius: 6px;
    background: var(--bg);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-meta);
    transition: all .2s;
  }
  .social-btn:hover { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }

  @media (max-width: 640px) {
    .profile-avatar { width: 56px; height: 56px; }
    .profile-name { font-size: 15px; }
    .profile-bio { font-size: 11px; }
    .profile-stat-num { font-size: 16px; }
    .widget-body { padding: 14px var(--space-card); }
  }

  /* Small phones */
  @media (max-width: 480px) {
    .profile-avatar { width: 50px; height: 50px; border-width: 2.5px; }
    .profile-name { font-size: 14px; }
    .profile-bio { font-size: 10.5px; line-height: 1.5; }
    .profile-stats { gap: 4px; padding: 8px 0; }
    .widget-body { padding: 12px var(--space-card); }
  }
</style>
