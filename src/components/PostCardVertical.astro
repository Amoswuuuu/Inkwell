---
import { SITE } from '../config';
import { displayTag } from '../utils/tag';
import { normalizeCats } from '../utils/posts';

interface Props {
  slug: string;
  title: string;
  date: Date;
  cover?: string;
  categories?: string | string[];
  tags?: string | string[];
  description?: string;
  aiSummary?: string[];
}

const { slug, title, date, cover, categories, description, tags, aiSummary } = Astro.props;

const cats = normalizeCats(categories);
const rawTags = Array.isArray(tags) ? tags : (tags ? [tags] : []);
const tagList = rawTags.flatMap(t =>
  typeof t === 'string' && t.includes(',')
    ? t.split(',').map(s => s.trim()).filter(Boolean)
    : [t]
);

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric', month: '2-digit', day: '2-digit',
}).replace(/\//g, '-');

// 首页卡片始终显示 description（完整一句话），不显示 AI 摘要要点列表
const excerpt = description || null;
---

<article class="pcard-v">
  <a href={`/posts/${slug}/`} class="pcard-v-img-wrap" aria-hidden="true" tabindex="-1">
    {cover
      ? <img class="pcard-v-img" src={cover} alt={title} loading="lazy" decoding="async" fetchpriority="low" style="height:100%" />
      : <div class="pcard-v-img-placeholder"></div>
    }
  </a>

  <div class="pcard-v-body">
    <div class="pcard-v-meta">
      {cats.slice(0, 1).map(cat => (
        <a class="badge" href={`/categories/${encodeURIComponent(cat)}`}>{cat}</a>
      ))}
      <span class="badge-date">{dateStr}</span>
    </div>

    <h2 class="pcard-v-title">
      <a href={`/posts/${slug}/`}>{title}</a>
    </h2>

    {/* Middle zone: description（完整一句话） */}
    <div class="pcard-v-middle">
      {excerpt
        ? <p class="pcard-v-excerpt">{excerpt}</p>
        : <div class="pcard-v-spacer"></div>
      }
    </div>

    <div class="pcard-v-footer">
      <div class="pcard-v-tags">
        {tagList.slice(0, 3).map(tag => (
          <a class="tag" href={`/tags/${encodeURIComponent(tag)}`}>#{displayTag(tag)}</a>
        ))}
      </div>
      <a class="read-more" href={`/posts/${slug}/`}>阅读全文</a>
    </div>
  </div>
</article>

<style>
  .pcard-v {
    background: var(--surface);
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .25s, box-shadow .25s;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .pcard-v:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }

  /* Cover image */
  .pcard-v-img-wrap {
    display: block;
    overflow: hidden;
    height: 200px;
    position: relative;
    flex-shrink: 0;
  }
  .pcard-v-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .pcard-v:hover .pcard-v-img { transform: scale(1.04); }
  .pcard-v-img-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--accent-soft), var(--tag-bg));
  }

  /* Body */
  .pcard-v-body {
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .pcard-v-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-flex;
    padding: 2px 9px;
    border-radius: var(--radius-badge);
    font-size: 12px;
    font-weight: 600;
    background: var(--tag-bg);
    color: var(--tag-text);
    white-space: nowrap;
    transition: background .2s, color .2s;
  }
  .badge:hover { background: var(--accent); color: #fff; }
  .badge-date { font-size: 12px; color: var(--text-muted); }

  .pcard-v-title {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .pcard-v-title a {
    color: var(--text-primary);
    transition: color .2s;
  }
  .pcard-v:hover .pcard-v-title a { color: var(--accent); }

  /* Middle content zone */
  .pcard-v-middle {
    flex: 1;
    min-height: 56px;
    min-width: 0;
  }
  .pcard-v-excerpt {
    font-size: 13px;
    color: var(--text-meta);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .pcard-v-ai {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .pcard-v-ai li {
    font-size: 12px;
    color: var(--text-meta);
    line-height: 1.6;
    padding-left: 14px;
    position: relative;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pcard-v-ai li::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--accent);
    font-weight: 700;
  }
  .pcard-v-spacer { height: 100%; }

  /* Footer */
  .pcard-v-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }
  .pcard-v-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    flex: 1;
    min-width: 0;
  }
  .tag {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 4px;
    transition: color .2s, border-color .2s;
  }
  .tag:hover { color: var(--accent); border-color: var(--accent); }
  .read-more {
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }
  .read-more::after {
    content: "→";
    transition: transform .2s;
    display: inline-block;
  }
  .pcard-v:hover .read-more::after { transform: translateX(3px); }

  /* ── Tailwind md breakpoint (768px) ── */
  @media (max-width: 768px) {
    .pcard-v-img-wrap { height: 170px; }
    .pcard-v-body { padding: 14px 16px 12px; }
    .pcard-v-title { font-size: 16px; }
    .pcard-v-excerpt { -webkit-line-clamp: 2; }
  }

  /* ── Tailwind sm breakpoint (640px) ── */
  @media (max-width: 640px) {
    .pcard-v-img-wrap { height: 160px; }
    .pcard-v-title { font-size: 15px; }
    .pcard-v-excerpt { font-size: 12px; }
    .pcard-v-footer { flex-wrap: wrap; }
  }

  /* Small phones (480px) */
  @media (max-width: 480px) {
    .pcard-v-img-wrap { height: 145px; }
    .pcard-v-body { padding: 13px 14px 11px; gap: 7px; }
    .pcard-v-title { font-size: 14.5px; -webkit-line-clamp: 2; }
    .pcard-v-excerpt { -webkit-line-clamp: 2; }
  }

  /* Ultra-small phones (400px) */
  @media (max-width: 400px) {
    .pcard-v-img-wrap { height: 130px; }
    .pcard-v-body { padding: 11px 12px; gap: 6px; }
    .pcard-v-title { font-size: 14px; }
    .badge { padding: 2px 8px; font-size: 11px; }
    .tag { padding: 2px 5px; font-size: 10px; }
    .read-more { font-size: 11px; }
  }
</style>
