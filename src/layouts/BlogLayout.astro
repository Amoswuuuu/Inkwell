  }
  .inkwell-lightbox-close:hover { color: #fff; }
  /* Make prose images feel clickable */
  .prose img { cursor: zoom-in; }

  /* Sidebar */
  .post-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 20px);
    display: flex;
