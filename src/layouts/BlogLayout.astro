</style>

<script is:inline>
  // Reading progress bar
  (function () {
    var bar = document.getElementById('reading-progress');
    if (!bar) return;
    function update() {
      var scrollTop = window.scrollY;
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) + '%' : '0%';
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.prose pre').forEach(function (pre) {
      // Extract language from class name (rehype-pretty-code adds language class)
      var code = pre.querySelector('code');
      var language = '';
      var filename = '';

      if (code) {
        // Try data-language first (set by rehype-pretty-code meta)
        language = code.getAttribute('data-language') || '';

        // Extract from class: language-js, language-typescript, etc.
        if (!language) {
          var classList = code.className || pre.className || '';
          var langMatch = classList.match(/language-(\w+)/);
          if (langMatch) language = langMatch[1];
        }

        // Extract filename from data-meta (e.g., {myfile.ts} in markdown)
        var meta = code.getAttribute('data-meta') || pre.getAttribute('data-meta') || '';
        var filenameMatch = meta.match(/\{([^}]+)\}/);
        if (filenameMatch) filename = filenameMatch[1];
      }

      // Add metadata attributes for AI agents
      if (language) {
        pre.setAttribute('data-language', language);
        pre.setAttribute('aria-label', language + ' code');
      }
      if (filename) {
        pre.setAttribute('data-filename', filename);
      }

      // Wrap pre in a relative container
      var wrap = document.createElement('div');
      wrap.className = 'code-wrap';
      pre.parentNode.insertBefore(wrap, pre);
      wrap.appendChild(pre);



      var btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', '复制代码');
      var SVG_COPY = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      var SVG_CHECK = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      btn.innerHTML = SVG_COPY + '复制';
      wrap.appendChild(btn);

      btn.addEventListener('click', function () {
        var code = pre.querySelector('code');
        var text = code ? code.innerText : pre.innerText;
        navigator.clipboard.writeText(text).then(function () {
          btn.classList.add('copied');
          btn.innerHTML = SVG_CHECK + '已复制';
          setTimeout(function () {
            btn.classList.remove('copied');
            btn.innerHTML = SVG_COPY + '复制';
          }, 1500);
        });
      });
    });
  });
</script>
