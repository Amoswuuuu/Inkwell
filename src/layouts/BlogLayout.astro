  .related-card:hover .related-title { color: var(--accent); }
  .related-date { font-size: 11px; color: var(--text-muted); margin-top: 5px; }

  /* Post Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
