---
import { SITE } from '../config';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  math?: boolean;
}

const {
  title,
  description = SITE.author.bio.split('\n')[0],
  ogImage = SITE.heroImage,
  noIndex = false,
  math = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === SITE.title ? title : `${title} — ${SITE.title}`;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#4b7bec" />

    <!-- iOS PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={SITE.title} />

    <!-- AI/Agent access meta -->
    <meta name="robots" content="index, follow" />
    <meta name="ai-content" content="read-friendly" />
    <link rel="alternate" type="application/json" title="JSON Feed" href="/feed.json" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

    <!-- Head slot for page-specific meta (JSON-LD, OpenGraph article, etc.) -->
    <slot name="head" />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('inkwell-theme') || 'auto';
        var effective;
        if (t === 'auto') {
          effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        } else {
          effective = t;
        }
        if (effective === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        else document.documentElement.removeAttribute('data-theme');
      })();
    </script>

    <!-- Umami analytics (only injected when enabled in config.yml) -->
    {SITE.stats.umami.enabled && SITE.stats.umami.src && SITE.stats.umami.websiteId && (
      <script
        defer
        src={SITE.stats.umami.src}
        data-website-id={SITE.stats.umami.websiteId}
      ></script>
    )}

    <!-- Pagefind: loaded on demand when search is opened -->

    <!-- KaTeX (only load when math rendering is needed) -->
    {math && (
      <>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-UF1fgpAiu3tPJN/uCqEUHNe7pnr+QR0SQDNfgglgtcM=" crossorigin="anonymous" />
      </>
    )}
  </head>
  <body>
    <Navbar />
    <Search />
    <main class="main-content" style="margin-top: var(--nav-height)">
      <slot />
    </main>
    <Footer />

    <!-- Back to top button -->
    <button id="back-to-top" aria-label="返回顶部" title="返回顶部">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    <script is:inline>
      (function () {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function () {
          if (window.scrollY > 400) {
            btn.classList.add('visible');
          } else {
            btn.classList.remove('visible');
          }
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
    <style is:inline>
      /* ═══════════════════════════════════════════════════════════════════
         Responsive Layout v5 — Minimal overrides only
         
         PRINCIPLE: BaseLayout only handles GLOBAL layout (containers, navbar).
         Component styles stay in their own .astro files with scoped CSS.
         NO component-level styles here to avoid overriding scoped CSS.
         ═══════════════════════════════════════════════════════════════════ */

      /* ── 1. Global Reset & Safety Net ── */
      *, *::before, *::after { box-sizing: border-box; }
      html {
        max-width: 100vw !important;
        -webkit-text-size-adjust: 100%;
      }
      body {
        max-width: 100vw !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      img:not([style*="height:"]):not(.hero-img):not(.post-card-img):not(.pcard-v-img) { 
        max-width: 100% !important; height: auto !important; 
      }

      /* ── 2. Page Container Padding ── */
      @media (max-width: 768px) {
        .main-wrap {
          padding-left: 20px !important;
          padding-right: 20px !important;
        }
      }
      @media (max-width: 480px) {
        .main-wrap {
          padding-left: 16px !important;
          padding-right: 16px !important;
          padding-top: 20px !important;
          padding-bottom: 36px !important;
        }
      }

      /* ── 3. Navbar Padding ── */
      @media (max-width: 768px) {
        .navbar-inner {
          padding-left: 20px !important;
          padding-right: 20px !important;
        }
      }
      @media (max-width: 480px) {
        .navbar-inner {
          padding-left: 16px !important;
          padding-right: 16px !important;
        }
        .navbar-logo { font-size: 16px !important; gap: 5px !important; }
        .logo-icon { width: 22px !important; height: 22px !important; }
        .theme-opt[data-theme-val="auto"] { display: none !important; }
        .theme-opt { width: 32px !important; height: 32px !important; }
        .btn-icon#search-btn { width: 32px !important; height: 32px !important; }
        .nav-hamburger { width: 32px !important; height: 32px !important; }
      }

      /* ── 4. HeroBanner height only ── */
      @media (max-width: 768px) {
        .hero.hero-banner { height: 260px !important; }
      }
      @media (max-width: 480px) {
        .hero.hero-banner { height: 220px !important; }
        .hero-banner .hero-title { font-size: 21px !important; }
        .hero-banner .hero-sub { font-size: 13px !important; opacity: .8 !important; }
        .hero-banner .hero-stats { gap: 12px !important; }
      }

      /* ── 5. BlogLayout hero + article ── */
      @media (max-width: 768px) {
        .hero.post-hero { height: 260px !important; }
        .hero.post-hero > .hero-content { padding: 20px 20px !important; }
        .article-card { padding: 20px 20px !important; }
      }
      @media (max-width: 480px) {
        .hero.post-hero { height: 220px !important; }
        .hero.post-hero > .hero-content { padding: 16px 16px !important; }
        .hero.post-hero > .hero-content > .hero-title { font-size: 19px !important; }
        .article-card { padding: 14px 16px !important; }
        .post-nav-item { padding: 12px 12px !important; }
      }

      /* ── 6. Sidebar grid layout (from index.astro context) ── */
      @media (max-width: 1080px) {
        .main-wrap-index > .sidebar {
          grid-template-columns: 1fr 1fr !important;
          gap: 16px !important;
        }
      }
      @media (max-width: 640px) {
        .main-wrap-index > .sidebar { grid-template-columns: 1fr !important; }
      }
      @media (max-width: 480px) {
        .section-header-text { font-size: 16px !important; }
        .post-grid, .post-list { gap: 16px !important; }
      }

      /* ── 7. Code blocks & prose ── */
      .prose pre { overflow-x: auto; max-width: 100% !important; }
      @media (max-width: 480px) {
        .prose pre {
          font-size: 12.5px;
          padding: 12px 12px !important;
          -webkit-overflow-scrolling: touch;
        }
        .prose { font-size: 16px; line-height: 1.75; }
        .prose h2 { font-size: 19px; margin: 28px 0 10px; padding-left: 10px; }
        .prose h3 { font-size: 16px; margin: 20px 0 8px; }
      }

      /* ── 8. Back to top button ── */
      #back-to-top {
        position: fixed;
        right: 24px; bottom: 32px; z-index: 900;
        width: 42px; height: 42px; border-radius: 50%;
        background: var(--accent); color: #fff; border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 14px rgba(0,0,0,.18);
        opacity: 0; transform: translateY(12px); pointer-events: none;
        transition: opacity .25s, transform .25s;
      }
      #back-to-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
      #back-to-top:hover { filter: brightness(1.12); transform: translateY(-2px); }
    </style>

    <!-- KaTeX auto-render (only load when math rendering is needed) -->
    {math && (
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" integrity="sha384-3ISyluw+iE3gkxWPdg/Z1Ftser5YtTgVV/ThOPRqWK4=" crossorigin="anonymous"></script>
      <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" integrity="sha384-nLjaz8CGwpZsnsS6VPSi3EO3y+KzPOwaJ0PYhsf7R6c=" crossorigin="anonymous"></script>
      <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
          renderMathInElement(document.body, {
            delimiters: [
              { left: '$$', right: '$$', display: true },
              { left: '$', right: '$', display: false },
              { left: '\\[', right: '\\]', display: true },
              { left: '\\(', right: '\\)', display: false },
            ],
            throwOnError: false
          });
        });
      </script>
    )}

    <!-- Lazy load images in article content -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Add loading="lazy" to all images in .prose that don't have it
        document.querySelectorAll('.prose img').forEach(function(img) {
          if (!img.hasAttribute('loading')) {
            img.setAttribute('loading', 'lazy');
          }
        });
      });
    </script>

    <!-- Service Worker Registration -->
    <script is:inline>
      (function() {
        // Force SW update check on every load for development phase
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', function() {
            navigator.serviceWorker.register('/sw.js').then(function(reg) {
              console.log('SW registered');
              // Check for updates immediately
              reg.update();
              // If new SW waiting, activate it
              reg.addEventListener('updatefound', function() {
                var newWorker = reg.installing;
                newWorker.addEventListener('statechange', function() {
                  if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                    // New content available, force activate
                    newWorker.postMessage({type: 'SKIP_WAITING'});
                  }
                });
              });
            });
            // Listen for controller change and reload once
            var reloaded = false;
            navigator.serviceWorker.addEventListener('controllerchange', function() {
              if (!reloaded) {
                reloaded = true;
                window.location.reload();
              }
            });
          });
        }
      })();
    </script>
  </body>
</html>
