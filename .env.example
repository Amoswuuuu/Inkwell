# ═══════════════════════════════════════════════════════════════════════════
# Inkwell AI Provider API Keys
# ═══════════════════════════════════════════════════════════════════════════
# 
# 在 config.yml 的 ai.providers 中选择一个 provider，然后填写对应的 API Key。
# 只需要配置你使用的 provider，其他可以留空。
#

# ── OpenAI (及其兼容服务) ────────────────────────────────────────────────
# 支持所有 OpenAI 兼容 API：OpenAI 官方、Azure、LongCat、DeepSeek、智谱等
# 在 config.yml 中配置 endpoint 即可切换服务
OPENAI_API_KEY=sk-xxx

# ── Anthropic Claude ───────────────────────────────────────────────────────
# 获取地址：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Google Gemini ──────────────────────────────────────────────────────────
# 获取地址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ── 自定义 OpenAI 兼容服务示例 ─────────────────────────────────────────────
# 如果使用第三方兼容服务（如 LongCat），可以添加自定义变量
# LONGCAT_API_KEY=ak_xxx
